    <Target Name="PostBuild" AfterTargets="PostBuildEvent">
      <Exec Command="xcopy /Y $(projectDir)$(outDir)Luban.Gdscript.dll D:\work\slg\common\config\Tools\Luban" />
    </Target>

</Project>
